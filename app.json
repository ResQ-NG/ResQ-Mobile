{
  "expo": {
    "name": "ResQ",
    "slug": "ResQ-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0a0a0a"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sheryf.ResQMobile",
      "infoPlist": {
        "NSCameraUsageDescription": "ResQ uses your camera to capture photos and videos for emergency reports.",
        "NSMicrophoneUsageDescription": "ResQ uses your microphone to record audio with video evidence."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.sheryf.ResQMobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "resq-mobile",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 50.4,
          "imageHeight": 50.4,
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      ["react-native-vision-camera"],
      ["@rnmapbox/maps"],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ResQ uses your location to show your position on the map and for emergency reports."
        }
      ],
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ResQ needs access to your photos for reports.",
          "savePhotosPermission": "ResQ saves photos to your library when you download."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
